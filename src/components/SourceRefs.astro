---
interface SourceRef {
  label: string;
  url: string;
}

interface Props {
  refs: SourceRef[];
}

const { refs } = Astro.props;
---

{
  refs.length > 0 && (
    <aside class="source-list" aria-labelledby="source-refs-title">
      <h2 id="source-refs-title">Source References</h2>
      <ul>
        {refs.map((ref) => (
          <li>
            <a href={ref.url} target="_blank" rel="noreferrer">
              {ref.label}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}
